# ─── Backend (copie para .env e preencha os valores) ───────────────────────

# Banco de dados
# Desenvolvimento: deixe em branco para usar SQLite local (conectapet.db)
# Produção (Neon): postgres://user:password@host/dbname?sslmode=require
DATABASE_URL=

# JWT — troque por uma string longa e aleatória em produção
JWT_SECRET=conectapet-dev-secret-troque-em-producao

# Credenciais do usuário admin (criado automaticamente na 1ª execução)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# URL do frontend em produção (ex: https://conectapet.vercel.app)
# Deixe em branco para usar http://localhost:5173
FRONTEND_URL=

# Porta do servidor (o Render define isso automaticamente)
# PORT=8080


# ─── Frontend (crie frontend/.env.local e preencha) ────────────────────────

# URL da API em produção (ex: https://conectapet-api.onrender.com/api)
# Deixe em branco para usar http://localhost:8080/api
# VITE_API_URL=
